# Canonical pins for this repo's Dockerfile. Bump via scripts/bump-pin.sh.
# Last updated: 2026-05-06 (Wave 13 cu13 cascade)
DEEPEP_FORK=https://github.com/dmvevents/DeepEP-1.git
DEEPEP_BRANCH=aws-efa-auto-qp-cap-v2
DEEPEP_SHA=146cc356aa00c39ac1590c05775e05b0f031e70c

# CUDA runtime (cu13 throughout; Wave 13 cu13 cascade unifies torch cu130 +
# base-image NCCL + DeepEP .so. Base image v0.2.5-sm90a is a cu13-native
# rebuild; all artifacts now share the cu13 ABI, resolving the Wave 11
# "invalid device ordinal" crash traced to the cu12/cu13 ABI split.)
# Quote the NCCL pin so `. ./pins.env` does not interpret `>=` as a shell redirect.
NVIDIA_NCCL_PIN="nvidia-nccl-cu13>=2.30.4"
BASE_IMAGE_FAST=ghcr.io/antonai-work/deepep-v2-efa-base:v0.2.5-sm90a
